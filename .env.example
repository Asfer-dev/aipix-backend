# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aipix"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="your-secret-key-here-change-in-production"

# SMTP Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@aipix.com"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="aipix-uploads"

# AI Service (Python FastAPI Backend)
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="your-ai-service-secret-key"

# Mock AI Processing (for testing without AI service)
# Set to "true" to use 10-second mock processing instead of real AI service
# The mock will return the original image as the "enhanced" version
USE_MOCK_AI="false"

# AI Content Moderation Service
AI_MODERATION_URL="http://localhost:8001"
AI_MODERATION_API_KEY="your-moderation-api-key-here"
AI_MODERATION_API_KEY=your-secret-key

# Frontend URL (for CORS and email links)
FRONTEND_URL="http://localhost:3000"
